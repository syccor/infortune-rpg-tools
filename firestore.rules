rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn();
      allow delete: if false;
    }

    match /characters/{document} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /classes/{document} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /subClasses/{document} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /races/{document} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /grades/{document} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /armorTypes/{document} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /shieldTypes/{document} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /weightClasses/{document} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /musculatureClasses/{document} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /sizeClasses/{document} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /raceMorphologies/{document} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}