{
  "name": "infortune-rpg-tools",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "deploy": "ng build --base-href=/infortune-rpg-tools/ && npx angular-cli-ghpages --dir=dist/infortune-rpg-tools/browser",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "seed:classes": "node firebase/seeds/seedClasses.js",
    "seed:races": "node firebase/seeds/seedRaces.js",
    "seed:subclasses": "node firebase/seeds/seedSubClasses.js",
    "seed:weights": "node firebase/seeds/seedWeightClasses.js",
    "seed:musculature": "node firebase/seeds/seedMusculatureClasses.js",
    "seed:sizes": "node firebase/seeds/seedSizeClasses.js",
    "seed:all": "node firebase/seeds/seedAll.js"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "firebase": "^11.10.0",
    "firebase-admin": "^13.7.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.20",
    "@angular/cli": "^20.3.20",
    "@angular/compiler-cli": "^20.3.0",
    "@types/jasmine": "~5.1.0",
    "angular-cli-ghpages": "^3.0.2",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.2"
  }
}
